  "db_name": "PostgreSQL",
  "query": "\n        UPDATE users\n        SET\n            display_name = CASE WHEN $2 THEN $3 ELSE display_name END,\n            role = COALESCE($4, role)\n        WHERE id = $1\n        RETURNING id, username, display_name, email, avatar_url, role, is_banned, created_at as \"created_at!\"\n        ",
