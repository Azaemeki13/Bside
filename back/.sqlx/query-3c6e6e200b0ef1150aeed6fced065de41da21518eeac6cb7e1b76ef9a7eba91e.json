{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            id,\n            sender_id,\n            receiver_id,\n            content,\n            status,\n            created_at,\n            delivered_at,\n            read_at\n        FROM messages\n        WHERE\n            (sender_id = $1 AND receiver_id = $2)\n            OR\n            (sender_id = $2 AND receiver_id = $1)\n        ORDER BY created_at ASC\n        ",
