{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            id,\n            title,\n            owner_id,\n            COALESCE(song_count, 0) as \"song_count!\",\n            is_public as \"is_public!\",\n            created_at as \"created_at!\",\n            cover_url\n        FROM playlists\n        WHERE owner_id = $1\n        ORDER BY created_at DESC\n        ",
