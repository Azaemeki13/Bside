{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            ar.id,\n            ar.user_id,\n            u.username,\n            u.email,\n            ar.artist_name,\n            ar.bio,\n            ar.status,\n            ar.reviewed_by,\n            ar.reviewed_at,\n            ar.created_at AS \"created_at!\"\n        FROM artist_requests ar\n        JOIN users u ON u.id = ar.user_id\n        WHERE ar.status = 'Pending'\n        ORDER BY ar.created_at ASC\n        ",
