  "query": "\n        INSERT INTO artist_requests (id, user_id, artist_name, bio)\n        VALUES ($1, $2, $3, $4)\n        RETURNING\n            id,\n            user_id,\n            (SELECT username FROM users WHERE id = $2) AS \"username!\",\n            (SELECT email FROM users WHERE id = $2) AS \"email!\",\n            artist_name,\n            bio,\n            status,\n            reviewed_by,\n            reviewed_at,\n            created_at AS \"created_at!\"\n        ",
