{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            s.id,\n            s.title,\n            s.duration_seconds,\n            s.audio_url,\n            s.status::text AS \"status!\",\n            ar.name AS \"artist_name!\",\n            a.cover_url AS \"cover_url!\"\n        FROM songs s\n        JOIN albums a ON a.id = s.album_id\n        JOIN artists ar ON ar.id = a.artist_id\n        WHERE\n            s.id = $1\n            AND s.status = 'Ready'\n        ",
